GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=your_random_secret_32chars
NEXTAUTH_URL=http://localhost:3000

# Опционально: сайт в Search Console (с точным URL как в GSC)
GSC_SITE_URL=https://example.com/

# GA4: numeric property id (из Admin → Property settings)
GA4_PROPERTY_ID=

# Опционально
AHREFS_API_KEY=

# --- Яндекс (Вебмастер + Метрика), отдельно от Google ---
# Создайте приложение: https://oauth.yandex.ru/client/new
# Права: metrika:read; в интерфейсе включите доступ к API Вебмастера.
# Redirect URI: {NEXTAUTH_URL}/api/yandex/oauth/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
# Необязательно: явный scope (через пробел). Если не задан — Яндекс берёт
# все права из настроек приложения (удобно для Метрика + Вебмастер).
# YANDEX_OAUTH_SCOPE=metrika:read
# Токен вручную для сервера/CI (если не используете OAuth в браузере)
# YANDEX_OAUTH_TOKEN=
# Явно указать сайт в Вебмастере и счётчик Метрики
# YANDEX_WEBMASTER_HOST_ID=
# YANDEX_METRICA_COUNTER_ID=
